rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /artifacts/{appId}/public/data/{document=**} {
      // Require authentication for all workspace data
      allow read, write: if request.auth != null;
    }
    
    match /games/{gameId}/scores/{userId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == userId || userId.size() > 0);
    }
  }
}
